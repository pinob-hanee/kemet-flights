datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  ADMIN
  VENDOR
  SUPPORT
  AFFILIATE
}

enum BookingType {
  FLIGHT
  HOTEL
  TOUR
  CRUISE
  TRANSPORT
  VISA
  INSURANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  passwordHash       String
  name               String
  role               Role                 @default(CUSTOMER)
  phone              String?
  avatarUrl          String?
  isEmailVerified    Boolean              @default(false)
  loyaltyPoints      Int                  @default(0)
  walletBalance      Decimal              @default(0.00) @db.Decimal(12, 2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  
  refreshTokens      RefreshToken[]
  sessions           Session[]
  bookings           Booking[]
  reviews            Review[]
  loyaltyTransactions LoyaltyTransaction[]
  walletTransactions WalletTransaction[]
  notifications      Notification[]
  supportTickets     SupportTicket[]
  auditLogs          AuditLog[]
  duffelOrders       DuffelOrder[]
  
  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  token        String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  revoked      Boolean   @default(false)
  replacedBy   String?
  createdAt    DateTime  @default(now())
  
  @@map("refresh_tokens")
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress    String
  userAgent    String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  
  @@map("sessions")
}

model AuditLog {
  id           String    @id @default(uuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  ipAddress    String
  userAgent    String
  details      Json?
  createdAt    DateTime  @default(now())
  
  @@map("audit_logs")
}

model Destination {
  id           String        @id @default(uuid())
  nameEn       String
  nameAr       String
  descriptionEn String       @db.Text
  descriptionAr String       @db.Text
  imageUrl     String
  isFeatured   Boolean       @default(false)
  hotels       Hotel[]
  tours        TourPackage[]
  
  @@map("destinations")
}

model Hotel {
  id            String        @id @default(uuid())
  nameEn        String
  nameAr        String
  descriptionEn String        @db.Text
  descriptionAr String        @db.Text
  destinationId String
  destination   Destination   @relation(fields: [destinationId], references: [id])
  starRating    Int           @default(5)
  addressEn     String
  addressAr     String
  images        String[]
  amenities     String[]
  latitude      Float?
  longitude     Float?
  basePrice     Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  rooms         Room[]
  
  @@map("hotels")
}

model Room {
  id            String         @id @default(uuid())
  hotelId       String
  hotel         Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  typeEn        String
  typeAr        String
  descriptionEn String         @db.Text
  descriptionAr String         @db.Text
  capacity      Int            @default(2)
  pricePerNight Decimal        @db.Decimal(10, 2)
  inventory     Int            @default(5)
  amenities     String[]
  images        String[]
  hotelBookings HotelBooking[]
  
  @@map("rooms")
}

model Flight {
  id               String          @id @default(uuid())
  flightNumber     String          @unique
  airlineEn        String
  airlineAr        String
  departureAirport String
  arrivalAirport   String
  departureTime    DateTime
  arrivalTime      DateTime
  priceEconomy     Decimal         @db.Decimal(10, 2)
  priceBusiness    Decimal         @db.Decimal(10, 2)
  priceFirstClass  Decimal         @db.Decimal(10, 2)
  baggagePolicyEn  String
  baggagePolicyAr  String
  flightBookings   FlightBooking[]
  
  @@map("flights")
}

model TourPackage {
  id            String        @id @default(uuid())
  nameEn        String
  nameAr        String
  descriptionEn String        @db.Text
  descriptionAr String        @db.Text
  destinationId String
  destination   Destination   @relation(fields: [destinationId], references: [id])
  durationDays  Int
  itineraryEn   Json          
  itineraryAr   Json
  price         Decimal       @db.Decimal(10, 2)
  maxGroupSize  Int           @default(12)
  images        String[]
  difficulty    String        @default("Easy")
  includesEn    String[]
  includesAr    String[]
  excludesEn    String[]
  excludesAr    String[]
  tourBookings  TourBooking[]
  
  @@map("tour_packages")
}

model Cruise {
  id             String          @id @default(uuid())
  nameEn         String
  nameAr         String
  descriptionEn  String          @db.Text
  descriptionAr  String          @db.Text
  itineraryEn    Json
  itineraryAr    Json
  durationNights Int
  cabinsCount    Int
  priceSuite     Decimal         @db.Decimal(10, 2)
  priceRoyal     Decimal         @db.Decimal(10, 2)
  images         String[]
  departurePortEn String
  departurePortAr String
  routePortsEn   String[]
  routePortsAr   String[]
  cruiseBookings CruiseBooking[]
  
  @@map("cruises")
}

model Booking {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            BookingType
  status          BookingStatus @default(PENDING)
  totalPrice      Decimal       @db.Decimal(12, 2)
  bookingDate     DateTime      @default(now())
  startDate       DateTime
  endDate         DateTime
  referenceNumber String        @unique
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  hotelBooking    HotelBooking?
  flightBooking   FlightBooking?
  tourBooking     TourBooking?
  cruiseBooking   CruiseBooking?
  payments        Payment[]
  refunds         Refund[]
  reviews         Review[]
  
  @@map("bookings")
}

model HotelBooking {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomId     String
  room       Room     @relation(fields: [roomId], references: [id])
  guestsCount Int      @default(2)
  
  @@map("hotel_bookings")
}

model FlightBooking {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  flightId   String
  flight     Flight   @relation(fields: [flightId], references: [id])
  seatClass  String   
  seatNumber String
  passengers Json     
  
  @@map("flight_bookings")
}

model TourBooking {
  id            String      @id @default(uuid())
  bookingId     String      @unique
  booking       Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tourPackageId String
  tourPackage   TourPackage @relation(fields: [tourPackageId], references: [id])
  guestsCount   Int         @default(2)
  
  @@map("tour_bookings")
}

model CruiseBooking {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cruiseId   String
  cruise     Cruise   @relation(fields: [cruiseId], references: [id])
  cabinType  String   
  guestsCount Int      @default(2)
  
  @@map("cruise_bookings")
}

model Payment {
  id                   String        @id @default(uuid())
  bookingId            String
  booking              Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount               Decimal       @db.Decimal(12, 2)
  gateway              String        
  gatewayTransactionId String        @unique
  status               PaymentStatus @default(PENDING)
  currency             String        @default("USD")
  method               String
  createdAt            DateTime      @default(now())
  refunds              Refund[]
  
  @@map("payments")
}

model Refund {
  id           String        @id @default(uuid())
  bookingId    String
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentId    String
  payment      Payment       @relation(fields: [paymentId], references: [id])
  amount       Decimal       @db.Decimal(12, 2)
  status       String        @default("PENDING") 
  reason       String
  approvedBy   String?
  createdAt    DateTime      @default(now())
  
  @@map("refunds")
}

model Coupon {
  id               String    @id @default(uuid())
  code             String    @unique
  discountType     String    
  value            Decimal   @db.Decimal(10, 2)
  minBookingAmount Decimal   @default(0.00) @db.Decimal(10, 2)
  expiresAt        DateTime
  isActive         Boolean   @default(true)
  usageLimit       Int       @default(100)
  usageCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  
  @@map("coupons")
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  rating     Int      @default(5)
  comment    String   @db.Text
  isApproved Boolean  @default(false)
  targetType String   
  targetId   String
  createdAt  DateTime @default(now())
  
  @@map("reviews")
}

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        String   
  description String
  createdAt   DateTime @default(now())
  
  @@map("loyalty_transactions")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2)
  type        String   
  description String
  createdAt   DateTime @db.Date
  
  @@map("wallet_transactions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@map("notifications")
}

model SupportTicket {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  status    String          @default("OPEN") 
  priority  String          @default("MEDIUM") 
  createdAt DateTime        @default(now())
  messages  TicketMessage[]
  
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String
  message    String        @db.Text
  createdAt  DateTime      @default(now())
  
  @@map("ticket_messages")
}

// Duffel live flight orders — separate from legacy Flight model
model DuffelOrder {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duffelOrderId    String   @unique
  bookingReference String
  origin           String
  destination      String
  departureDate    String
  totalAmount      Float
  currency         String   @default("USD")
  passengerCount   Int      @default(1)
  cabinClass       String   @default("economy")
  airlineName      String?
  status           String   @default("CONFIRMED")
  createdAt        DateTime @default(now())

  @@map("duffel_orders")
}
